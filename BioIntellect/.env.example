# BioIntellect production stack environment template
# Copy to .env and fill in actual values; NEVER commit .env to git

# ── Network & Transport ─────────────────────────────────────────────
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

# ── Backend Runtime ────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
ENABLE_CACHING=true
MRI_SEGMENTATION_TIMEOUT_SECONDS=300

# ── Supabase Cloud DB ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=replace_with_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# ── CORS & Trusted Hosts (HTTPS) ───────────────────────────────────
# CORS_ORIGINS must NOT include localhost or 0.0.0.0 in production.
# For local Docker use: https://localhost
# For production: https://app.yourdomain.com
CORS_ORIGINS=https://app.biointellect.example
TRUSTED_HOSTS=app.biointellect.example,localhost,127.0.0.1

# Password reset redirect allowlist (hostnames only, comma-separated)
PASSWORD_RESET_REDIRECT_ALLOWLIST=app.biointellect.example,localhost,127.0.0.1

# ── Redis Caching (Password Required) ──────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Generate a strong password: openssl rand -base64 32
REDIS_PASSWORD=set_a_strong_redis_password_here
REDIS_SSL=false

# ── TLS/HTTPS Certificates (for nginx) ─────────────────────────────
# Provide paths to certificates if HTTPS is enabled in reverse-proxy
TLS_CERT_PATH=/etc/nginx/certs/server.crt
TLS_KEY_PATH=/etc/nginx/certs/server.key
# Or use certbot/Let's Encrypt mounts

# ── LLM & AI Providers ─────────────────────────────────────────────
GENERATION_BACKEND=openai
OPENAI_API_KEY=sk-proj-your-key-here
COHERE_API_KEY=replace_with_cohere_key
AI_PROVIDER_API_KEY=replace_if_using_custom_provider

# ── Vector Database (Qdrant) ───────────────────────────────────────
VECTOR_DB_BACKEND=qdrant
VECTOR_DB_PATH=/app/qdrant_storage

# ── Local Model Paths (if using local models) ──────────────────────
MEDMO_MODEL_PATH=/app/models/medmo
MEDMO_OFFLOAD_FOLDER=/app/offload
PHI_QA_MODEL_PATH=/app/models/phi_qa

# ── Frontend API Routes ────────────────────────────────────────────
VITE_API_URL=https://api.biointellect.example
VITE_API_ROOT_URL=https://api.biointellect.example/api
