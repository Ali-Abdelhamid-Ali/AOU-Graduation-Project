# BioIntellect Backend - Environment Template
# Copy to .env and replace placeholder values.

# Runtime
ENVIRONMENT=development
DEBUG=true
PORT=8000
SECRET_KEY=replace_with_long_random_secret
LOG_LEVEL=INFO

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=replace_with_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Database (optional if Supabase-only mode is used)
DATABASE_URL=

# CORS (comma-separated, required in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1

# Cache / Redis
ENABLE_CACHING=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# Rate limiting and retries
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
ENABLE_RETRIES=true

# Observability
ENABLE_FALLBACK_LOGGING=true
SLACK_WEBHOOK_URL=
HEALTH_CHECK_FAILURE_THRESHOLD=3

# Optional external providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER_API_KEY=
SENTRY_DSN=
